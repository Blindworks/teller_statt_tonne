# Kopiere diese Datei nach `.env` und ersetze alle <change-me>-Werte.
# Nicht in die Versionsverwaltung einchecken.

# --- Datenbank (MariaDB) ---
MARIADB_ROOT_PASSWORD=<change-me>
MARIADB_DATABASE=teller_statt_tonne
MARIADB_USER=tst
MARIADB_PASSWORD=<change-me>

# --- Backend ---
# Mindestens 32 Zeichen. Erzeugen z.B. mit: openssl rand -base64 48
JWT_SECRET=<change-me-min-32-chars>
ADMIN_EMAIL=admin@example.de
ADMIN_PASSWORD=<change-me>

# Komma-separierte Liste erlaubter Frontend-Origins (Schema + Host, ohne Pfad).
# Auf der VM: alle oeffentlich erreichbaren Varianten eintragen (apex + www, ggf. IP).
# Hinweis: Gilt nur fuer geschuetzte /api/**-Endpunkte. /api/public/** akzeptiert
# beliebige Origins (inkl. "null" aus In-App-Webviews) ohne Credentials.
# Lokal zum Testen: http://localhost:8081
CORS_ALLOWED_ORIGINS=https://teller-statt-tonne.example.de,https://www.teller-statt-tonne.example.de

# Basis-URL des Frontends fuer Links in Mails (Passwort-Reset, Einladung).
# Ohne abschliessenden Slash. Lokal: http://localhost:4200
FRONTEND_BASE_URL=https://teller-statt-tonne.example.de

# --- Mail (SMTP) ---
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.de
MAIL_FROM_NAME=Teller statt Tonne

# --- Web Push (VAPID) ---
# Einmalig erzeugen: `npx web-push generate-vapid-keys`. Der Public-Key muss
# byte-genau zur Konstante in frontend/src/environments/environment.prod.ts passen.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.de
