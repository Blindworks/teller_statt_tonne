{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: spring-boot:run",
      "type": "shell",
      "command": "./mvnw spring-boot:run",
      "windows": {
        "command": ".\\mvnw.cmd spring-boot:run"
      },
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "spring-boot",
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Starting BackendApplication.*",
          "endsPattern": ".*Started BackendApplication.*"
        }
      },
      "presentation": {
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "frontend: npm start",
      "type": "npm",
      "script": "start",
      "path": "frontend",
      "isBackground": true,
      "problemMatcher": {
        "owner": "angular",
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*(Building|Compiling|Initial chunk).*",
          "endsPattern": ".*(Local:\\s+http://localhost:4200|Application bundle generation complete).*"
        }
      },
      "presentation": {
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "dev: start all",
      "dependsOn": ["backend: spring-boot:run", "frontend: npm start"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
