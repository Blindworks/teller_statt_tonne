{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Backend: Spring Boot",
      "request": "launch",
      "mainClass": "de.tellerstatttonne.backend.BackendApplication",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "type": "chrome",
      "name": "Frontend: Chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/frontend/src",
      "preLaunchTask": "frontend: npm start"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Backend: Spring Boot", "Frontend: Chrome"],
      "stopAll": true
    }
  ]
}
