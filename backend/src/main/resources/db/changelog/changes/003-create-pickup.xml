<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="003-create-pickup" author="teller-statt-tonne">
        <createTable tableName="pickup">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="partner_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="pickup_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="start_time" type="VARCHAR(8)">
                <constraints nullable="false"/>
            </column>
            <column name="end_time" type="VARCHAR(8)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(16)" defaultValue="SCHEDULED">
                <constraints nullable="false"/>
            </column>
            <column name="capacity" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="VARCHAR(500)"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="pickup"
            baseColumnNames="partner_id"
            referencedTableName="partner"
            referencedColumnNames="id"
            constraintName="fk_pickup_partner"
            onDelete="CASCADE"/>

        <createIndex tableName="pickup" indexName="idx_pickup_date">
            <column name="pickup_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="003-create-pickup-assignment" author="teller-statt-tonne">
        <createTable tableName="pickup_assignment">
            <column name="pickup_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="slot_order" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="member_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
            tableName="pickup_assignment"
            columnNames="pickup_id, slot_order"
            constraintName="pk_pickup_assignment"/>

        <addForeignKeyConstraint
            baseTableName="pickup_assignment"
            baseColumnNames="pickup_id"
            referencedTableName="pickup"
            referencedColumnNames="id"
            constraintName="fk_pickup_assignment_pickup"
            onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
