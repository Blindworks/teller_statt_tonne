<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="025-app-user-onboarding-fields" author="teller-statt-tonne">
        <addColumn tableName="app_user">
            <column name="agreement_file_url" type="VARCHAR(1024)"/>
            <column name="agreement_uploaded_at" type="DATETIME(6)"/>
            <column name="test_pickup_completed_at" type="DATETIME(6)"/>
        </addColumn>
    </changeSet>

    <changeSet id="025-introduction-slot" author="teller-statt-tonne">
        <createTable tableName="introduction_slot">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="start_time" type="TIME">
                <constraints nullable="false"/>
            </column>
            <column name="end_time" type="TIME">
                <constraints nullable="false"/>
            </column>
            <column name="location" type="VARCHAR(255)"/>
            <column name="capacity" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="VARCHAR(1000)"/>
            <column name="created_by_user_id" type="BIGINT"/>
            <column name="created_at" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="introduction_slot" baseColumnNames="created_by_user_id"
                                 referencedTableName="app_user" referencedColumnNames="id"
                                 constraintName="fk_introduction_slot_created_by"
                                 onDelete="SET NULL"/>

        <createIndex tableName="introduction_slot" indexName="idx_introduction_slot_date">
            <column name="date"/>
        </createIndex>
    </changeSet>

    <changeSet id="025-introduction-booking" author="teller-statt-tonne">
        <createTable tableName="introduction_booking">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="slot_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="booked_at" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="cancelled_at" type="DATETIME(6)"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="introduction_booking" baseColumnNames="slot_id"
                                 referencedTableName="introduction_slot" referencedColumnNames="id"
                                 constraintName="fk_introduction_booking_slot"
                                 onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="introduction_booking" baseColumnNames="user_id"
                                 referencedTableName="app_user" referencedColumnNames="id"
                                 constraintName="fk_introduction_booking_user"
                                 onDelete="CASCADE"/>

        <createIndex tableName="introduction_booking" indexName="idx_introduction_booking_slot">
            <column name="slot_id"/>
        </createIndex>
        <createIndex tableName="introduction_booking" indexName="idx_introduction_booking_user_active"
                     unique="true">
            <column name="user_id"/>
            <column name="cancelled_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
