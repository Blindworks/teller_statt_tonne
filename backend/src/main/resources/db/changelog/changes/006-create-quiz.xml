<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="006-create-quiz-question" author="teller-statt-tonne">
        <createTable tableName="quiz_question">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="text" type="CLOB">
                <constraints nullable="false"/>
            </column>
            <column name="weight" type="DECIMAL(3,1)">
                <constraints nullable="false"/>
            </column>
            <column name="order_index" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="006-create-quiz-answer" author="teller-statt-tonne">
        <createTable tableName="quiz_answer">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="question_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="text" type="VARCHAR(1024)">
                <constraints nullable="false"/>
            </column>
            <column name="is_correct" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="is_knockout" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="order_index" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="quiz_answer"
            baseColumnNames="question_id"
            referencedTableName="quiz_question"
            referencedColumnNames="id"
            constraintName="fk_quiz_answer_question"
            onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="006-create-quiz-result-category" author="teller-statt-tonne">
        <createTable tableName="quiz_result_category">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="label" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="color" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="min_score" type="DECIMAL(5,2)">
                <constraints nullable="false"/>
            </column>
            <column name="max_score" type="DECIMAL(5,2)"/>
            <column name="order_index" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="006-seed-quiz-result-category" author="teller-statt-tonne">
        <insert tableName="quiz_result_category">
            <column name="id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="label" value="geeignet"/>
            <column name="color" value="GREEN"/>
            <column name="min_score" valueNumeric="0.0"/>
            <column name="max_score" valueNumeric="1.0"/>
            <column name="order_index" valueNumeric="0"/>
        </insert>
        <insert tableName="quiz_result_category">
            <column name="id" value="22222222-2222-2222-2222-222222222222"/>
            <column name="label" value="Gespräch / Probeabholung"/>
            <column name="color" value="YELLOW"/>
            <column name="min_score" valueNumeric="1.5"/>
            <column name="max_score" valueNumeric="2.0"/>
            <column name="order_index" valueNumeric="1"/>
        </insert>
        <insert tableName="quiz_result_category">
            <column name="id" value="33333333-3333-3333-3333-333333333333"/>
            <column name="label" value="nicht geeignet"/>
            <column name="color" value="RED"/>
            <column name="min_score" valueNumeric="2.5"/>
            <column name="max_score"/>
            <column name="order_index" valueNumeric="2"/>
        </insert>
    </changeSet>

    <changeSet id="006-create-quiz-attempt" author="teller-statt-tonne">
        <createTable tableName="quiz_attempt">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="applicant_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="applicant_email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="score" type="DECIMAL(5,2)">
                <constraints nullable="false"/>
            </column>
            <column name="result_category_label" type="VARCHAR(64)"/>
            <column name="result_color" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="knockout_triggered" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="completed_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="006-create-quiz-attempt-answer" author="teller-statt-tonne">
        <createTable tableName="quiz_attempt_answer">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="attempt_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="question_id" type="VARCHAR(36)"/>
            <column name="question_text" type="VARCHAR(2048)"/>
            <column name="question_weight" type="DECIMAL(3,1)">
                <constraints nullable="false"/>
            </column>
            <column name="was_correct" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="order_index" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="quiz_attempt_answer"
            baseColumnNames="attempt_id"
            referencedTableName="quiz_attempt"
            referencedColumnNames="id"
            constraintName="fk_quiz_attempt_answer_attempt"
            onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="006-modify-quiz-question-text" author="teller-statt-tonne">
        <modifyDataType tableName="quiz_question" columnName="text" newDataType="VARCHAR(2048)"/>
    </changeSet>

    <changeSet id="006-create-quiz-attempt-selected" author="teller-statt-tonne">
        <createTable tableName="quiz_attempt_selected_answer">
            <column name="attempt_answer_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="selection_order" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="answer_id" type="VARCHAR(36)"/>
            <column name="answer_text" type="VARCHAR(1024)"/>
            <column name="was_knockout" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
            tableName="quiz_attempt_selected_answer"
            columnNames="attempt_answer_id, selection_order"
            constraintName="pk_quiz_attempt_selected_answer"/>

        <addForeignKeyConstraint
            baseTableName="quiz_attempt_selected_answer"
            baseColumnNames="attempt_answer_id"
            referencedTableName="quiz_attempt_answer"
            referencedColumnNames="id"
            constraintName="fk_quiz_attempt_selected_attempt_answer"
            onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
