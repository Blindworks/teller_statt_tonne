<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="006-create-push-subscription" author="teller-statt-tonne">
        <createTable tableName="push_subscription">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="endpoint" type="VARCHAR(1024)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_push_subscription_endpoint"/>
            </column>
            <column name="p256dh" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="auth" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="user_agent" type="VARCHAR(512)"/>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="push_subscription" baseColumnNames="user_id"
                                 referencedTableName="app_user" referencedColumnNames="id"
                                 constraintName="fk_push_subscription_user" onDelete="CASCADE"/>
        <createIndex tableName="push_subscription" indexName="idx_push_subscription_user">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
