<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="011-create-partner-note" author="teller-statt-tonne">
        <createTable tableName="partner_note">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="partner_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="author_user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="body" type="VARCHAR(4000)">
                <constraints nullable="false"/>
            </column>
            <column name="visibility" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="DATETIME(6)"/>
            <column name="deleted_by_user_id" type="BIGINT"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="partner_note" baseColumnNames="partner_id"
                                 referencedTableName="partner" referencedColumnNames="id"
                                 constraintName="fk_partner_note_partner"/>
        <addForeignKeyConstraint baseTableName="partner_note" baseColumnNames="author_user_id"
                                 referencedTableName="app_user" referencedColumnNames="id"
                                 constraintName="fk_partner_note_author"/>
        <addForeignKeyConstraint baseTableName="partner_note" baseColumnNames="deleted_by_user_id"
                                 referencedTableName="app_user" referencedColumnNames="id"
                                 constraintName="fk_partner_note_deleted_by" onDelete="SET NULL"/>

        <createIndex tableName="partner_note" indexName="idx_partner_note_partner_created">
            <column name="partner_id"/>
            <column name="created_at" descending="true"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
