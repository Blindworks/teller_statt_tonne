<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="013-create-partner-application" author="teller-statt-tonne">
        <createTable tableName="partner_application">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="partner_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="message" type="VARCHAR(1000)"/>
            <column name="decision_reason" type="VARCHAR(1000)"/>
            <column name="decided_by_user_id" type="BIGINT"/>
            <column name="created_at" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="decided_at" type="DATETIME(6)"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="partner_application" baseColumnNames="partner_id"
                                 referencedTableName="partner" referencedColumnNames="id"
                                 constraintName="fk_partner_application_partner"/>
        <addForeignKeyConstraint baseTableName="partner_application" baseColumnNames="user_id"
                                 referencedTableName="app_user" referencedColumnNames="id"
                                 constraintName="fk_partner_application_user"/>
        <addForeignKeyConstraint baseTableName="partner_application" baseColumnNames="decided_by_user_id"
                                 referencedTableName="app_user" referencedColumnNames="id"
                                 constraintName="fk_partner_application_decided_by"
                                 onDelete="SET NULL"/>

        <createIndex tableName="partner_application" indexName="idx_partner_application_partner_status">
            <column name="partner_id"/>
            <column name="status"/>
        </createIndex>
        <createIndex tableName="partner_application" indexName="idx_partner_application_user_status">
            <column name="user_id"/>
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
