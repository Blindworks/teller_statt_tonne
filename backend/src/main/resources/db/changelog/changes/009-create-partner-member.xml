<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="009-create-partner-member" author="teller-statt-tonne">
        <createTable tableName="partner_member">
            <column name="partner_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="member_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
            tableName="partner_member"
            columnNames="partner_id, member_id"
            constraintName="pk_partner_member"/>

        <addForeignKeyConstraint
            baseTableName="partner_member"
            baseColumnNames="partner_id"
            referencedTableName="partner"
            referencedColumnNames="id"
            constraintName="fk_partner_member_partner"
            onDelete="CASCADE"/>

        <addForeignKeyConstraint
            baseTableName="partner_member"
            baseColumnNames="member_id"
            referencedTableName="member"
            referencedColumnNames="id"
            constraintName="fk_partner_member_member"
            onDelete="CASCADE"/>

        <createIndex tableName="partner_member" indexName="idx_partner_member_member">
            <column name="member_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="009-add-pickup-saved-kg" author="teller-statt-tonne">
        <addColumn tableName="pickup">
            <column name="saved_kg" type="DECIMAL(10,2)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
