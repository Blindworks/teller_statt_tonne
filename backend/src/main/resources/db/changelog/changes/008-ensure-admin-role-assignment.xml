<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        Sicherheitsnetz fuer den Rollen-Umbau (007): Falls der bekannte Admin-Account
        auf Prod (admin@example.de) bzw. Dev (admin@local) bei der 007-Migration
        keine ADMINISTRATOR-Rolle hatte (z.B. weil die alte app_user.role-Spalte
        bereits vorher leer war), wird die Verknuepfung hier idempotent ergaenzt.
        NOT EXISTS verhindert duplizierte Inserts.
    -->
    <changeSet id="008-ensure-admin-role-assignment" author="teller-statt-tonne">
        <sql>
            INSERT INTO user_role (user_id, role_id)
            SELECT u.id, r.id
            FROM app_user u
            CROSS JOIN role r
            WHERE u.email IN ('admin@example.de', 'admin@local')
              AND r.name = 'ADMINISTRATOR'
              AND NOT EXISTS (
                SELECT 1 FROM user_role ur
                WHERE ur.user_id = u.id AND ur.role_id = r.id
              )
        </sql>
    </changeSet>

</databaseChangeLog>
