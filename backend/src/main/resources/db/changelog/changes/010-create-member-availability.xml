<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="010-create-member-availability" author="teller-statt-tonne">
        <createTable tableName="member_availability">
            <column name="id" type="VARCHAR(36)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_member_availability"/>
            </column>
            <column name="member_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="weekday" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="start_time" type="VARCHAR(8)">
                <constraints nullable="false"/>
            </column>
            <column name="end_time" type="VARCHAR(8)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="member_availability"
            baseColumnNames="member_id"
            referencedTableName="member"
            referencedColumnNames="id"
            constraintName="fk_member_availability_member"
            onDelete="CASCADE"/>

        <addUniqueConstraint
            tableName="member_availability"
            columnNames="member_id, weekday, start_time, end_time"
            constraintName="uq_member_availability"/>

        <createIndex tableName="member_availability" indexName="idx_member_availability_match">
            <column name="weekday"/>
            <column name="start_time"/>
            <column name="end_time"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
