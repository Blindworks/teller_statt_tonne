<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="001-create-partner" author="teller-statt-tonne">
        <createTable tableName="partner">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="street" type="VARCHAR(255)"/>
            <column name="postal_code" type="VARCHAR(16)"/>
            <column name="city" type="VARCHAR(255)"/>
            <column name="logo_url" type="VARCHAR(1024)"/>
            <column name="contact_name" type="VARCHAR(255)"/>
            <column name="contact_email" type="VARCHAR(255)"/>
            <column name="contact_phone" type="VARCHAR(64)"/>
            <column name="status" type="VARCHAR(16)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-create-partner-pickup-slot" author="teller-statt-tonne">
        <createTable tableName="partner_pickup_slot">
            <column name="partner_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="slot_order" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="weekday" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="start_time" type="VARCHAR(8)"/>
            <column name="end_time" type="VARCHAR(8)"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
            tableName="partner_pickup_slot"
            columnNames="partner_id, slot_order"
            constraintName="pk_partner_pickup_slot"/>

        <addForeignKeyConstraint
            baseTableName="partner_pickup_slot"
            baseColumnNames="partner_id"
            referencedTableName="partner"
            referencedColumnNames="id"
            constraintName="fk_partner_pickup_slot_partner"
            onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
